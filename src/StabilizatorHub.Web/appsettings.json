{
  "Urls": "http://127.0.0.1:5000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "DataDirectory": "data"
  },
  "Mqtt": {
    "Enabled": true,
    "Host": "localhost",
    "Port": 1883,
    "Username": "backend",
    "Password": "",
    "ClientId": "stabilizatorhub-backend",
    "TopicRoot": "stabilizator",
    "ReconnectDelaySeconds": 5
  },
  "VoltageMonitor": {
    "UndervoltageLimit": 215.0,
    "OvervoltageLimit": 240.0,
    "HysteresisVolts": 2.0
  },
  "Telemetry": {
    "OfflineAfterSeconds": 180,
    "MaxEnergyGapMinutes": 5,
    "RawRetentionDays": 0
  },
  "TelemetryLog": {
    "Enabled": true,
    "Directory": "logs",
    "RetentionDays": 90,
    "KeyBase64": ""
  },
  "Update": {
    "Enabled": true,
    "GitHubOwner": "DeiuVRG",
    "GitHubRepo": "StabilizatorHubVRG",
    "TriggerFilePath": ""
  },
  "Admin": {
    "Email": "",
    "Password": ""
  }
